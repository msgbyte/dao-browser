diff --git a/chrome/app/app-Info.plist b/chrome/app/app-Info.plist
index e813de1e4e..51be2e1056 100644
--- a/chrome/app/app-Info.plist
+++ b/chrome/app/app-Info.plist
@@ -149,8 +149,11 @@
 	<string>${EXECUTABLE_NAME}</string>
 	<key>CFBundleIconFile</key>
 	<string>app.icns</string>
-	<key>CFBundleIconName</key>
-	<string>AppIcon</string>
+	<!-- Dao Browser: CFBundleIconName was intentionally removed. When both
+	     keys are present, macOS prefers IconName (read from Assets.car's
+	     compiled "AppIcon" bundle), which makes our custom app.icns
+	     invisible. Dropping IconName forces macOS to fall back to
+	     IconFile=app.icns, which is the file we ship in branding/mac/. -->
 	<key>CFBundleIdentifier</key>
 	<string>${CHROMIUM_BUNDLE_ID}</string>
 	<key>CFBundleInfoDictionaryVersion</key>
@@ -161,5 +164,10 @@
 	<key>CFBundleName</key>
 	<string>${CHROMIUM_SHORT_NAME}</string>
+	<!-- Dao Browser: Scope the user data directory by the product short
+	     name so debug and release builds keep isolated profiles
+	     (~/Library/Application Support/Dao vs .../Dao Debug). -->
+	<key>CrProductDirName</key>
+	<string>${CHROMIUM_SHORT_NAME}</string>
 	<key>CFBundlePackageType</key>
 	<string>APPL</string>
 	<key>CFBundleSignature</key>
@@ -723,5 +731,31 @@
 	<array>
 		<string>_googlecast._tcp</string>
 	</array>
+	<!-- Dao Browser: Sparkle auto-update configuration.
+	     Behaviour is configured declaratively here so changing the update
+	     policy (interval, automatic install, feed URL) doesn't require a
+	     code change. See src/dao/browser/updater/dao_sparkle_updater_mac.mm
+	     for the C++ side. -->
+	<key>SUFeedURL</key>
+	<string>https://dao.msgbyte.com/appcast.xml</string>
+	<!-- EdDSA public key for verifying appcast signatures. The matching
+	     private key lives in the developer's login keychain (created via
+	     `npm run sparkle:keygen`). Sparkle refuses any update whose
+	     signature does not validate against this key, so rotating the
+	     public key here without rotating the private key in the keychain
+	     will brick the auto-updater.
+	     Backup procedure: see docs/release-signing.md → "Sparkle keys". -->
+	<key>SUPublicEDKey</key>
+	<string>dz3KV6hBHuxJGYXru/dOYip1oSBH5o02nrdGZdWF8x4=</string>
+	<key>SUEnableAutomaticChecks</key>
+	<true/>
+	<key>SUAutomaticallyUpdate</key>
+	<true/>
+	<!-- 3600 seconds = 1 hour. Sparkle's documented minimum is 3600. -->
+	<key>SUScheduledCheckInterval</key>
+	<integer>3600</integer>
+	<!-- We sign all artifacts; do NOT allow insecure HTTP feed URLs. -->
+	<key>SUEnableInstallerLauncherService</key>
+	<true/>
 </dict>
 </plist>
