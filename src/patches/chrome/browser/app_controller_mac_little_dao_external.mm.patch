+
+  // Dao: native macOS external URL events arrive here when the app is already
+  // running. Open those URLs in Little Dao and return before the normal-browser
+  // NTP replacement cleanup below can close an existing main-window tab.
+  if (profile->GetPrefs()->GetBoolean(dao::prefs::kDaoLittleDaoEnabled)) {
+    custom_handlers::ProtocolHandlerRegistry* registry =
+        ProtocolHandlerRegistryFactory::GetForBrowserContext(profile);
+    bool opened_little_dao = false;
+    for (const GURL& url : urls) {
+      const bool handled_by_chrome =
+          ProfileIOData::IsHandledURL(url) ||
+          (registry && registry->IsHandledProtocol(url.GetScheme()));
+      if (!handled_by_chrome) {
+        continue;
+      }
+      dao::DaoLittleDaoController::OpenInLittleDao(profile, url);
+      opened_little_dao = true;
+    }
+    if (opened_little_dao) {
+      return;
+    }
+  }
