+bool MatchLegacyChromeScheme(GURL* url,
+                             content::BrowserContext* browser_context) {
+  // Dao: this "handler" only exists so that BrowserURLHandlerImpl will pair
+  // it with ReverseChromeAboutAndChromeSyncRewrite. Returning true here means
+  // ReverseURLRewrite will invoke our reverse rewriter to rewrite the
+  // virtual_url. We do NOT modify *url, so this is effectively a marker.
+  //
+  // RewriteURLIfNecessary path: it runs after the real rewriter above has
+  // already mapped chrome:// to dao://, so *url has the dao:// scheme and
+  // we return false (no-op), letting HandleWebUI further down the chain
+  // route the WebUI normally.
+  //
+  // ReverseURLRewrite path: each iteration resets test_url to the original
+  // pre-rewrite URL (which is chrome:// for hardcoded callers), so we hit
+  // chrome:// here, return true, and the reverse rewriter then rewrites the
+  // virtual_url to the dao:// scheme.
+  return url->SchemeIs("chrome");
+}
+
+bool ReverseChromeAboutAndChromeSyncRewrite(
+    GURL* url,
+    content::BrowserContext* browser_context) {
+  // Dao: rewrite the virtual URL so that the omnibox shows "dao://settings"
+  // rather than the legacy "chrome://settings" that some hardcoded Chromium
+  // callers still pass to navigation. Paired with MatchLegacyChromeScheme.
+  if (url->SchemeIs("chrome")) {
+    GURL::Replacements replacements;
+    replacements.SetSchemeStr(content::kChromeUIScheme);
+    *url = url->ReplaceComponents(replacements);
+    return true;
+  }
+  return false;
+}
