@@ -490,3 +493,18 @@ void AutoPictureInPictureTabHelper::MaybeEnterAutoPictureInPicture() {
   auto_pip_trigger_reason_ = GetAutoPipReason();
-  content::MediaSession::Get(web_contents())->EnterAutoPictureInPicture();
+  // Dao: Intercept configured sites for Document PiP with DOM element.
+  if (dao::DaoPipInterceptor::ShouldIntercept(web_contents())) {
+    auto* pip_interceptor =
+        dao::DaoPipInterceptor::FromWebContents(web_contents());
