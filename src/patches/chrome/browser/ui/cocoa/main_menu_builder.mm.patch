diff --git a/chrome/browser/ui/cocoa/main_menu_builder.mm b/chrome/browser/ui/cocoa/main_menu_builder.mm
index b0dcd2691b..d105f8847b 100644
--- a/chrome/browser/ui/cocoa/main_menu_builder.mm
+++ b/chrome/browser/ui/cocoa/main_menu_builder.mm
@@ -9,6 +9,7 @@
 #include "base/mac/mac_util.h"
 #include "build/branding_buildflags.h"
 #include "chrome/app/chrome_command_ids.h"
+#include "dao/browser/strings/grit/dao_strings.h"
 #include "chrome/browser/browser_features.h"
 #include "chrome/browser/browser_process.h"
 #include "chrome/browser/feedback/report_unsafe_site_dialog.h"
@@ -112,6 +113,24 @@ + (instancetype)imageWithPrivateSystemSymbolName:(NSString*)name
 
   nsapp.servicesMenu = services_item.submenu;
 
+  // Dao: Insert "Check for Updates..." right after "About Dao", followed by a
+  // separator. This is the standard Apple HIG location for the auto-update
+  // entry point. The action is dispatched via commandDispatch: → handled by
+  // either AppController (no key window) or BrowserWindowCommandHandler
+  // (key window present). Both routes call DaoUpdaterService.
+  NSMenu* app_submenu = item.submenu;
+  NSInteger about_index = [app_submenu indexOfItemWithTag:IDC_ABOUT];
+  if (about_index != -1) {
+    NSMenuItem* check_updates_item = [[NSMenuItem alloc]
+        initWithTitle:l10n_util::GetNSString(IDS_DAO_CHECK_FOR_UPDATES_MENU)
+               action:@selector(commandDispatch:)
+        keyEquivalent:@""];
+    check_updates_item.tag = IDC_DAO_CHECK_FOR_UPDATES;
+    [app_submenu insertItem:check_updates_item atIndex:about_index + 1];
+    [app_submenu insertItem:[NSMenuItem separatorItem]
+                    atIndex:about_index + 2];
+  }
+
   return item;
 }
 
@@ -171,6 +189,18 @@ + (instancetype)imageWithPrivateSystemSymbolName:(NSString*)name
           .Build();
   // clang-format on
 
+  // Dao: Insert "New Little Dao" menu item after "New Incognito Window"
+  NSMenu* file_menu = item.submenu;
+  NSInteger incognito_index =
+      [file_menu indexOfItemWithTag:IDC_NEW_INCOGNITO_WINDOW];
+  NSInteger insert_index = (incognito_index != -1) ? incognito_index + 1 : 3;
+  NSMenuItem* little_dao_item = [[NSMenuItem alloc]
+      initWithTitle:@"New Little Dao"
+             action:@selector(commandDispatch:)
+      keyEquivalent:@""];
+  little_dao_item.tag = IDC_NEW_LITTLE_DAO;
+  [file_menu insertItem:little_dao_item atIndex:insert_index];
+
   return item;
 }
 
@@ -282,6 +312,20 @@ + (instancetype)imageWithPrivateSystemSymbolName:(NSString*)name
           })
           .Build();
   // clang-format on
+
+  // Dao: Insert "Copy URL" menu item after "Copy" with Cmd+Shift+C
+  NSMenu* edit_menu = item.submenu;
+  NSInteger copy_index =
+      [edit_menu indexOfItemWithTag:IDC_CONTENT_CONTEXT_COPY];
+  NSMenuItem* copy_url_item = [[NSMenuItem alloc]
+      initWithTitle:@"Copy URL"
+             action:@selector(commandDispatch:)
+      keyEquivalent:@"c"];
+  copy_url_item.keyEquivalentModifierMask =
+      NSEventModifierFlagCommand | NSEventModifierFlagShift;
+  copy_url_item.tag = IDC_DAO_COPY_URL;
+  [edit_menu insertItem:copy_url_item atIndex:copy_index + 1];
+
   return item;
 }
 
@@ -618,6 +662,17 @@ + (instancetype)imageWithPrivateSystemSymbolName:(NSString*)name
           .Build();
   // clang-format on
 
+  // Dao: Prepend "Welcome to Dao" at the top of the Help menu, followed by a
+  // separator so it reads as its own section.
+  NSMenu* help_menu = item.submenu;
+  NSMenuItem* welcome_item = [[NSMenuItem alloc]
+      initWithTitle:@"Welcome to Dao"
+             action:@selector(commandDispatch:)
+      keyEquivalent:@""];
+  welcome_item.tag = IDC_DAO_WELCOME;
+  [help_menu insertItem:welcome_item atIndex:0];
+  [help_menu insertItem:[NSMenuItem separatorItem] atIndex:1];
+
   nsapp.helpMenu = item.submenu;
   return item;
 }
