 content::WebContents& NewTab(Browser* browser) {
+  // Dao: When the sidebar is active, don't create a tab immediately.
+  // Instead show the command bar so the user can type a URL first.
+  // The tab will be created when the user presses Enter.
+  BrowserView* dao_bv = BrowserView::GetBrowserViewForBrowser(browser);
+  if (dao_bv && dao_bv->dao_sidebar() && dao_bv->dao_sidebar()->GetVisible()) {
+    if (dao_bv->dao_command_bar()) {
+      dao_bv->dao_command_bar()->ShowForNewTab();
+    }
+    // Must still return a valid WebContents reference.  Return the
+    // currently-active tab (which hasn't changed).
+    return *browser->tab_strip_model()->GetActiveWebContents();
+  }
+
   base::RecordAction(UserMetricsAction("NewTab"));
