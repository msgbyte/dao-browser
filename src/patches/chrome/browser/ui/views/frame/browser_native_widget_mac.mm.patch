+bool IsDaoCommandSShortcut(const input::NativeWebKeyboardEvent& event) {
+  if (event.GetType() != blink::WebInputEvent::Type::kRawKeyDown) {
+    return false;
+  }
+
+  constexpr int kDisallowedModifiers = blink::WebInputEvent::kShiftKey |
+                                       blink::WebInputEvent::kControlKey |
+                                       blink::WebInputEvent::kAltKey;
+  const int modifiers = event.GetModifiers();
+  return event.windows_key_code == ui::VKEY_S &&
+         (modifiers & blink::WebInputEvent::kMetaKey) &&
+         !(modifiers & kDisallowedModifiers);
+}
