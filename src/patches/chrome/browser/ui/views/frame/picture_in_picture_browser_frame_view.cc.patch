 void PictureInPictureBrowserFrameView::OnWidgetActivationChanged(
     views::Widget* widget,
     bool active) {
+  // Dao: Suppress first activation so window starts compact (no top bar).
+  if (!dao_pip_first_activation_suppressed_) {
+    dao_pip_first_activation_suppressed_ = true;
+    return;
+  }
   // The window may become inactive when a popup modal shows, so we need to
