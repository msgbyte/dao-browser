   UpdateTopBarView(active || mouse_inside_window_ || IsOverlayViewVisible());
@@ -1179,6 +1185,14 @@ void PictureInPictureBrowserFrameView::AnimationEnded(
   if (animation == &top_bar_color_animation_) {
     current_foreground_color_ = std::nullopt;
     location_icon_view_->Update(/*suppress_animations=*/false);
+    // Dao: When hide completes, atomically flip layout + shrink window.
+    if (animation->GetCurrentValue() == 0.0 && GetWidget()) {
+      dao_pip_top_bar_expanded_ = false;
+      gfx::Rect bounds = GetWidget()->GetWindowBoundsInScreen();
+      GetWidget()->SetBounds(gfx::Rect(
