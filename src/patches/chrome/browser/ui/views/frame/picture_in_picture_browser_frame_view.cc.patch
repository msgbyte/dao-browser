+void PictureInPictureBrowserFrameView::DaoInitializeTopBarOverlay() {
+  // Dao: Guard against double-init and against the (expected but defensive)
+  // case where the container view was never built.
+  if (dao_top_bar_overlay_widget_ || !dao_top_bar_container_owned_) {
+    return;
+  }
+
+  auto overlay = std::make_unique<views::Widget>();
+  views::Widget::InitParams params(
+      views::Widget::InitParams::WIDGET_OWNS_NATIVE_WIDGET,
+      views::Widget::InitParams::TYPE_POPUP);
+  params.opacity = views::Widget::InitParams::WindowOpacity::kTranslucent;
+  // Dao: Do not steal focus; the top bar buttons handle clicks directly on the
+  // overlay widget without needing to activate the window.
+  params.activatable = views::Widget::InitParams::Activatable::kNo;
+  params.accept_events = true;
+  params.remove_standard_frame = true;
+  params.shadow_type = views::Widget::InitParams::ShadowType::kNone;
+  params.name = "DaoPipTopBarOverlay";
+  params.parent = GetWidget()->GetNativeView();
+  params.bounds = gfx::Rect();
+  overlay->Init(std::move(params));
+  overlay->SetContentsView(std::move(dao_top_bar_container_owned_));
+  dao_top_bar_overlay_widget_ = std::move(overlay);
+
+  // Dao: Install a post-target mouse handler on the overlay's root view so
+  // drags in non-button areas of the top bar move the main PiP window.
+  dao_overlay_drag_handler_ = std::make_unique<OverlayDragHandler>(GetWidget());
+  dao_top_bar_overlay_widget_->GetRootView()->AddPostTargetHandler(
+      dao_overlay_drag_handler_.get());
+
+  // Dao: Do not set bounds or show here. At AddedToWidget() time, this frame
+  // view has not been laid out yet so GetLocalBounds() is empty, and SetBounds
+  // with an empty rect crashes on macOS (NativeWidgetMacNSWindowHost refuses
+  // zero-sized windows). Layout() will call DaoUpdateTopBarOverlayBounds(),
+  // which then sets bounds and shows the widget.
+}
+
+void PictureInPictureBrowserFrameView::DaoUpdateTopBarOverlayBounds() {
+  if (!dao_top_bar_overlay_widget_ || !GetWidget()) {
+    return;
+  }
+  // Dao: Compute the overlay rect in screen coordinates, matching the original
+  // top-bar position (content area top, minus frame border). The content
+  // container inside the overlay lays itself out to fill the widget.
+  gfx::Rect content_area = GetLocalBounds();
+  content_area.Inset(FrameBorderInsets());
+  gfx::Rect top_bar_local = content_area;
+  top_bar_local.set_height(kTopControlsHeight);
+  // Dao: Skip while the frame view has not been laid out yet. macOS refuses
+  // zero-sized NSWindows and SetBounds() with an empty rect would CHECK-fail.
+  if (top_bar_local.IsEmpty()) {
+    return;
+  }
+  gfx::Point origin = top_bar_local.origin();
+  views::View::ConvertPointToScreen(this, &origin);
+  gfx::Rect overlay_bounds_in_screen(origin, top_bar_local.size());
+  if (dao_top_bar_overlay_widget_->GetWindowBoundsInScreen() !=
+      overlay_bounds_in_screen) {
+    dao_top_bar_overlay_widget_->SetBounds(overlay_bounds_in_screen);
+  }
+  // Dao: Show on first valid bounds. ShowInactive keeps focus on the main
+  // PiP window.
+  if (!dao_top_bar_overlay_widget_->IsVisible()) {
+    dao_top_bar_overlay_widget_->ShowInactive();
+  }
+}
