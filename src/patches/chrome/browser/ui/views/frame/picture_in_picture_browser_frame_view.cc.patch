   }
 
@@ -1368,6 +1383,15 @@ void PictureInPictureBrowserFrameView::UpdateTopBarView(bool render_active) {
       hide_all_buttons_animation_.Stop();
     }
 
+    // Dao: Atomically flip layout + expand window upward.
+    if (GetWidget()) {
+      dao_pip_top_bar_expanded_ = true;
+      gfx::Rect bounds = GetWidget()->GetWindowBoundsInScreen();
+      GetWidget()->SetBounds(gfx::Rect(
