+// Dao: PostTargetHandler installed on the top-bar overlay widget's root view
+// so that dragging in non-button areas of the floating top bar moves the main
+// PiP window. Runs after the target view (e.g. a button) has had a chance to
+// handle the event; if the event is already handled we leave it alone. This
+// keeps the overlay as an independent NSWindow (so button hit-tests are not
+// shadowed by WebContents) while still giving users a draggable caption.
+class OverlayDragHandler : public ui::EventHandler {
+ public:
+  explicit OverlayDragHandler(views::Widget* main_widget)
+      : main_widget_(main_widget) {}
+  OverlayDragHandler(const OverlayDragHandler&) = delete;
+  OverlayDragHandler& operator=(const OverlayDragHandler&) = delete;
+  ~OverlayDragHandler() override = default;
+
+  void OnMouseEvent(ui::MouseEvent* event) override {
+    if (event->handled() || !main_widget_) {
+      return;
+    }
+    if (!event->IsLeftMouseButton() &&
+        event->type() != ui::EventType::kMouseReleased) {
+      return;
+    }
+
+    switch (event->type()) {
+      case ui::EventType::kMousePressed: {
+        drag_start_mouse_screen_ =
+            display::Screen::Get()->GetCursorScreenPoint();
+        drag_start_widget_bounds_ = main_widget_->GetWindowBoundsInScreen();
+        dragging_ = true;
+        event->SetHandled();
+        break;
+      }
+      case ui::EventType::kMouseDragged: {
+        if (!dragging_) {
+          break;
+        }
+        gfx::Point current =
+            display::Screen::Get()->GetCursorScreenPoint();
+        gfx::Vector2d delta = current - drag_start_mouse_screen_;
+        gfx::Rect new_bounds = drag_start_widget_bounds_;
+        new_bounds.Offset(delta);
+        main_widget_->SetBounds(new_bounds);
+        event->SetHandled();
+        break;
+      }
+      case ui::EventType::kMouseReleased: {
+        dragging_ = false;
+        break;
+      }
+      default:
+        break;
+    }
+  }
+
+ private:
+  raw_ptr<views::Widget> main_widget_;
+  gfx::Point drag_start_mouse_screen_;
+  gfx::Rect drag_start_widget_bounds_;
+  bool dragging_ = false;
+};
+
