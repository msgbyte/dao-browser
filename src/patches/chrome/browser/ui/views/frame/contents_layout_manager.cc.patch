 ContentsLayoutManager::ContentsLayoutManager(views::View* devtools_view,
@@ -47,6 +48,27 @@ views::ProposedLayout ContentsLayoutManager::CalculateProposedLayout(
   ApplyDevToolsContentsResizingStrategy(
       strategy_, container_size, &new_devtools_bounds, &new_contents_bounds);
 
+  // Dao: When split view is active, shrink the original ContentsWebView to a
+  // tiny non-zero rect so Chromium status bubble anchoring still has a valid
+  // base view, while DaoSplitView takes over the visible content area.
+  for (views::View* child : host_view()->children()) {
+    if (auto* split_view =
+            views::AsViewClass<dao::DaoSplitView>(child)) {
+      if (split_view->IsSplitActive()) {
+        // Keep a guaranteed non-zero anchor rect for StatusBubbleViews even
+        // during transient resize frames where the host container reports 0.
+        const int placeholder_width = std::max(1, std::min(width, 3));
+        const int placeholder_height = std::max(1, std::min(height, 1));
+        new_contents_bounds = gfx::Rect(
+            std::max(0, width - placeholder_width),
+            std::max(0, height - placeholder_height),
+            placeholder_width, placeholder_height);
+        new_devtools_bounds = gfx::Rect();
+        break;
+      }
+    }
+  }
