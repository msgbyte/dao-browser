+constexpr float kDaoPromptCornerRadius = 10.0f;
+constexpr gfx::Insets kDaoPromptPadding = gfx::Insets::TLBR(7, 11, 7, 11);
+
+SkColor DaoPromptBackground() {
+  return dao::IsDarkMode() ? SkColorSetRGB(63, 69, 76)
+                           : SkColorSetRGB(246, 248, 251);
+}
+
+SkColor DaoPromptBorder() {
+  return dao::IsDarkMode() ? SkColorSetARGB(72, 255, 255, 255)
+                           : SkColorSetARGB(36, 32, 44, 58);
+}
+
+SkColor DaoDialogContentBackground() {
+  return dao::IsDarkMode() ? SkColorSetRGB(47, 53, 60) : SK_ColorWHITE;
+}
+
+void ConfigureDaoPromptTextfield(views::Textfield* textfield) {
+  if (!textfield) {
+    return;
+  }
+
+  textfield->SetBackgroundColor(DaoPromptBackground());
+  textfield->SetTextColor(dao::TextPrimary());
+  textfield->SetBorder(views::CreatePaddedBorder(
+      views::CreateRoundedRectBorder(
+          1, kDaoPromptCornerRadius, ui::ColorVariant(DaoPromptBorder())),
+      kDaoPromptPadding));
+}
+
+views::ScrollView* FindDescendantScrollView(views::View* root) {
+  if (!root) {
+    return nullptr;
+  }
+
+  if (auto* scroll_view = views::AsViewClass<views::ScrollView>(root)) {
+    return scroll_view;
+  }
+
+  for (views::View* child : root->children()) {
+    if (auto* scroll_view = FindDescendantScrollView(child)) {
+      return scroll_view;
+    }
+  }
+  return nullptr;
+}
+
+}  // namespace
 
