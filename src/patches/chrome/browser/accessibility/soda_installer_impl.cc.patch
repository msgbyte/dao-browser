+  auto accumulate = [&](speech::LanguageCode code) {
+    auto it = downloading_components_.find(code);
+    if (it == downloading_components_.end()) return;
+    const auto& item = it->second;
+    if (item.total_bytes < 0 || item.downloaded_bytes < 0) return;
+    total_bytes += item.total_bytes;
+    downloaded_bytes += item.downloaded_bytes;
