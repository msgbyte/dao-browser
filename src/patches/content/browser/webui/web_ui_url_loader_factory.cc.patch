diff --git a/content/browser/webui/web_ui_url_loader_factory.cc b/content/browser/webui/web_ui_url_loader_factory.cc
index 6513c88de1..15125ae90b 100644
--- a/content/browser/webui/web_ui_url_loader_factory.cc
+++ b/content/browser/webui/web_ui_url_loader_factory.cc
@@ -276,7 +276,15 @@ class WebUIURLLoaderFactory : public network::SelfDeletingURLLoaderFactory {
       return;
     }
 
-    if (request.url.scheme() != scheme_) {
+    // Allow legacy "chrome" scheme requests to pass through when the primary
+    // WebUI scheme is "dao", since compiled WebUI resources still reference
+    // chrome:// URLs (e.g. chrome://resources/, chrome://theme/).
+    bool scheme_matches = (request.url.scheme() == scheme_) ||
+                          (scheme_ == kChromeUIScheme &&
+                           request.url.scheme() == "chrome") ||
+                          (scheme_ == "chrome" &&
+                           request.url.scheme() == kChromeUIScheme);
+    if (!scheme_matches) {
       DVLOG(1) << "Bad scheme: " << request.url.scheme();
       SCOPED_CRASH_KEY_STRING32("WebUI", "actual_scheme", request.url.scheme());
       SCOPED_CRASH_KEY_STRING32("WebUI", "expected_scheme", scheme_);
