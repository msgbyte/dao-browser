    <!-- The translation console uses 'no' for Norwegian Bokmål. It should
         be 'nb'. -->
    <output filename="dao_strings_nb.pak" type="data_package" lang="no" />
    <output filename="dao_strings_pa.pak" type="data_package" lang="pa" />
    <output filename="dao_strings_pl.pak" type="data_package" lang="pl" />
    <if expr="is_ios">
      <output filename="dao_strings_pt.pak" type="data_package" lang="pt-BR" />
    </if>
    <if expr="not is_ios">
      <output filename="dao_strings_pt-BR.pak" type="data_package" lang="pt-BR" />
    </if>
    <output filename="dao_strings_pt-PT.pak" type="data_package" lang="pt-PT" />
    <output filename="dao_strings_or.pak" type="data_package" lang="or" />
    <output filename="dao_strings_ro.pak" type="data_package" lang="ro" />
    <output filename="dao_strings_ru.pak" type="data_package" lang="ru" />
    <output filename="dao_strings_si.pak" type="data_package" lang="si" />
    <output filename="dao_strings_sk.pak" type="data_package" lang="sk" />
    <output filename="dao_strings_sl.pak" type="data_package" lang="sl" />
