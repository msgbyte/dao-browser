<?xml version="1.0" encoding="UTF-8"?>

<!-- Dao Browser strings. Mirrors Chromium's locale set (see ax_strings.grd).

     IDS_DAO_* identifiers are owned by Dao. Add new strings to the <messages>
     block at the bottom of this file, then run `tsx scripts/i18n-bootstrap.ts`
     to make sure every locale has an empty .xtb skeleton on disk.

     This file is regenerated in part: the <outputs> and <translations> blocks
     are produced by scripts/i18n-bootstrap.ts. The <messages> block is hand-
     authored — only the surrounding scaffolding is generated. -->

<grit base_dir="." latest_public_release="0" current_release="1"
      source_lang_id="en">
  <outputs>
    <output filename="grit/dao_strings.h" type="rc_header">
      <emit emit_type="prepend"></emit>
    </output>
    <output filename="dao_strings_af.pak" type="data_package" lang="af" />
    <output filename="dao_strings_am.pak" type="data_package" lang="am" />
    <output filename="dao_strings_ar.pak" type="data_package" lang="ar" />
    <output filename="dao_strings_as.pak" type="data_package" lang="as" />
    <output filename="dao_strings_az.pak" type="data_package" lang="az" />
    <output filename="dao_strings_be.pak" type="data_package" lang="be" />
    <output filename="dao_strings_bg.pak" type="data_package" lang="bg" />
    <output filename="dao_strings_bn.pak" type="data_package" lang="bn" />
    <output filename="dao_strings_bs.pak" type="data_package" lang="bs" />
    <output filename="dao_strings_ca.pak" type="data_package" lang="ca" />
    <output filename="dao_strings_cs.pak" type="data_package" lang="cs" />
    <output filename="dao_strings_cy.pak" type="data_package" lang="cy" />
    <output filename="dao_strings_da.pak" type="data_package" lang="da" />
    <output filename="dao_strings_de.pak" type="data_package" lang="de" />
    <output filename="dao_strings_el.pak" type="data_package" lang="el" />
    <output filename="dao_strings_en-GB.pak" type="data_package" lang="en-GB" />
    <output filename="dao_strings_en-US.pak" type="data_package" lang="en" />
    <output filename="dao_strings_es.pak" type="data_package" lang="es" />
    <if expr="is_ios">
      <output filename="dao_strings_es-MX.pak" type="data_package" lang="es-419" />
    </if>
    <if expr="not is_ios">
      <output filename="dao_strings_es-419.pak" type="data_package" lang="es-419" />
    </if>
    <output filename="dao_strings_et.pak" type="data_package" lang="et" />
    <output filename="dao_strings_eu.pak" type="data_package" lang="eu" />
    <output filename="dao_strings_fa.pak" type="data_package" lang="fa" />
    <output filename="dao_strings_fi.pak" type="data_package" lang="fi" />
    <output filename="dao_strings_fil.pak" type="data_package" lang="fil" />
    <output filename="dao_strings_fr-CA.pak" type="data_package" lang="fr-CA" />
    <output filename="dao_strings_fr.pak" type="data_package" lang="fr" />
    <output filename="dao_strings_gl.pak" type="data_package" lang="gl" />
    <output filename="dao_strings_gu.pak" type="data_package" lang="gu" />
    <output filename="dao_strings_he.pak" type="data_package" lang="he" />
    <output filename="dao_strings_hi.pak" type="data_package" lang="hi" />
    <output filename="dao_strings_hr.pak" type="data_package" lang="hr" />
    <output filename="dao_strings_hu.pak" type="data_package" lang="hu" />
    <output filename="dao_strings_hy.pak" type="data_package" lang="hy" />
