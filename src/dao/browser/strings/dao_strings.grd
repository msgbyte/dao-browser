  </translations>
  <release seq="1">
    <messages fallback_to_english="true">
      <!-- Sentinel string used to verify the i18n pipeline end-to-end. Safe to
           keep around indefinitely; it is not surfaced in real UI. -->
      <message name="IDS_DAO_TEST_PIPELINE" desc="Sentinel string used by the build to verify the Dao i18n pipeline is wired up correctly. Not user-facing.">
        Dao i18n pipeline OK
      </message>

      <!-- Sidebar / address bar -->
      <message name="IDS_DAO_SIDEBAR_TOGGLE_TOOLTIP" desc="Tooltip on the toggle button that hides or shows the Dao sidebar. The keyboard shortcut symbol after the label is the macOS Command key (⌘) followed by 'S'.">
        Toggle Sidebar (<ph name="SHORTCUT">⌘S</ph>)
      </message>
      <message name="IDS_DAO_SIDEBAR_TOGGLE_ACCESSIBLE_NAME" desc="Accessible name (read aloud by screen readers) for the sidebar toggle button.">
        Toggle Sidebar
      </message>
      <message name="IDS_DAO_SIDEBAR_TOGGLE_RETRY_TOAST" desc="Toast shown when a webpage handles the Command+S sidebar shortcut first. The keyboard shortcut symbol is the macOS Command key (⌘) followed by 'S'.">
        Press <ph name="SHORTCUT">⌘S</ph> again to toggle sidebar
      </message>
      <message name="IDS_DAO_UPDATE_READY_ACTION" desc="Label and tooltip for the sidebar button that applies a downloaded Dao Browser update.">
        Update
      </message>
      <message name="IDS_DAO_UPDATE_APPLYING_ACTION" desc="Transient label for the sidebar update button after the user clicks it and Dao starts applying the update.">
        Applying
      </message>
      <message name="IDS_DAO_CHECK_FOR_UPDATES_MENU" desc="Menu item in the macOS application menu that opens Dao Browser's Sparkle update checker. Uses title case to match neighboring macOS app menu commands.">
        Check for Updates...
      </message>
      <message name="IDS_DAO_CHECK_FOR_UPDATES_BUTTON" desc="Button on the macOS settings About page that opens Dao Browser's Sparkle update checker. Uses sentence case to match settings page button style.">
        Check for updates
      </message>
      <message name="IDS_DAO_ADDRESS_BAR_STOP_LOADING_ACCESSIBLE_NAME" desc="Accessible name for the button in the address bar that stops the current page from loading.">
        Stop Loading
      </message>
      <message name="IDS_DAO_ADDRESS_BAR_RELOAD_ACCESSIBLE_NAME" desc="Accessible name for the button in the address bar that reloads the current page.">
        Reload
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_DUPLICATE_TAB" desc="Context menu item that duplicates the selected regular tab in the Dao sidebar.">
        Duplicate Tab
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_COPY_LINK" desc="Context menu item that copies the URL of the selected regular tab in the Dao sidebar.">
        Copy Link
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_PIN_TAB" desc="Context menu item that pins a regular tab into the Dao sidebar pinned items section.">
        Pin Tab
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_MUTE_SITE" desc="Context menu item that mutes audio for the site in the selected regular tab in the Dao sidebar.">
        Mute Site
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_UNMUTE_SITE" desc="Context menu item that unmutes audio for the site in the selected regular tab in the Dao sidebar.">
        Unmute Site
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_CLOSE_TAB" desc="Context menu item that closes the selected regular tab in the Dao sidebar.">
        Close Tab
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_CLOSE_DUPLICATE_TABS" desc="Context menu item that closes open tabs whose URLs duplicate another open tab in the same Dao Browser window, keeping the most recently active tab for each URL.">
        Close Duplicate Tabs
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_CLOSE_OTHER_TABS" desc="Context menu item that closes all regular tabs except the selected tab in the Dao sidebar.">
        Close Other Tabs
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_CLOSE_TABS_ABOVE" desc="Context menu item that closes regular tabs above the selected tab in the Dao sidebar visual order.">
        Close Tabs Above
      </message>
      <message name="IDS_DAO_TAB_CONTEXT_CLOSE_TABS_BELOW" desc="Context menu item that closes regular tabs below the selected tab in the Dao sidebar visual order.">
        Close Tabs Below
      </message>
      <message name="IDS_DAO_SIDEBAR_CONTEXT_MOVE_STALE_TABS" desc="Context menu item in the Dao sidebar that moves tabs inactive for more than 24 hours into a folder named stale.">
        Move Stale Tabs to "stale"
      </message>
      <message name="IDS_DAO_SIDEBAR_STALE_TABS_ARCHIVED_TOAST" desc="Toast shown after the Dao sidebar moves tabs inactive for more than 24 hours into the stale folder.">
        Archived tabs inactive for the past 24 hours
      </message>
      <message name="IDS_DAO_SIDEBAR_NO_NEW_STALE_TABS_ARCHIVED_TOAST" desc="Toast shown when the user asks the Dao sidebar to archive stale tabs, but no additional tabs need to be moved.">
        No new tabs were archived
      </message>
      <message name="IDS_DAO_PINNED_TAB_CONTEXT_OPEN" desc="Context menu item that opens a dormant pinned sidebar item in a browser tab.">
        Open
      </message>
      <message name="IDS_DAO_PINNED_TAB_CONTEXT_UNPIN" desc="Context menu item that removes a pinned sidebar item from the pinned items section.">
        Unpin
      </message>
      <message name="IDS_DAO_PINNED_TAB_CONTEXT_CLOSE_TAB" desc="Context menu item that closes the open browser tab backing a pinned sidebar item without removing the pinned item.">
        Close Tab
      </message>
      <message name="IDS_DAO_PINNED_TAB_CONTEXT_COPY_LINK" desc="Context menu item that copies the URL for a pinned sidebar item to the clipboard.">
        Copy Link
      </message>
      <message name="IDS_DAO_FOLDER_CONTEXT_RENAME" desc="Context menu item that starts renaming a folder in the Dao sidebar.">
        Rename
      </message>
      <message name="IDS_DAO_FOLDER_CONTEXT_DELETE" desc="Context menu item that deletes a folder in the Dao sidebar. Tabs inside the folder remain open.">
        Delete Folder
      </message>

      <!-- Command bar -->
      <message name="IDS_DAO_COMMAND_BAR_PLACEHOLDER" desc="Placeholder text shown in the Spotlight-style command bar (Cmd+L) prompting the user to type either a URL or a search query.">
        Type a URL or search...
      </message>

      <!-- Suggestion item -->
      <message name="IDS_DAO_SUGGESTION_ASK_AI" desc="Title of a suggestion row that, when clicked, sends the user's typed text to the AI assistant. The PROMPT placeholder is the user's typed query, e.g. 'Ask AI: how do I bake bread?'.">
        Ask AI: <ph name="PROMPT">$1<ex>how do I bake bread?</ex></ph>
      </message>
      <message name="IDS_DAO_SUGGESTION_INTENT_SEARCH" desc="Short right-side intent label for a command bar suggestion that will run a web search.">
        Search
      </message>
      <message name="IDS_DAO_SUGGESTION_INTENT_OPEN" desc="Short right-side intent label for a command bar suggestion that will open a URL.">
        Open
      </message>
      <message name="IDS_DAO_SUGGESTION_INTENT_SWITCH_TAB" desc="Short right-side intent label for a command bar suggestion that will switch to an already-open tab.">
        Switch Tab
      </message>
      <message name="IDS_DAO_SUGGESTION_INTENT_ASK_DAO" desc="Short right-side intent label for a command bar suggestion that will send the typed prompt to the Dao assistant.">
        Ask Dao
      </message>

      <!-- Control Center -->
      <message name="IDS_DAO_CONTROL_CENTER_BUTTON_ACCESSIBLE_NAME" desc="Accessible name for the Control Center button (the gear/sliders icon in the sidebar that opens the settings popup).">
        Control Center
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_ADD_EXTENSION" desc="Tooltip and accessible name for the button that adds a new browser extension from the Control Center extensions section.">
        Add extension
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_MANAGE_EXTENSIONS" desc="Tooltip and accessible name for the button that opens the extensions management page from the Control Center.">
        Manage extensions
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_MINI_DAO" desc="Label and accessible name for the Control Center utility button that moves the current tab into a Mini Dao independent window.">
        Mini Dao
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_MINI_DAO_FAILED_TOAST" desc="Toast shown when the user clicks the Control Center Mini Dao button but the current tab cannot be moved into a Mini Dao window.">
        Could not open this tab in Mini Dao
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_BACK_BUTTON_LABEL" desc="Label on the back button in the Control Center 'More' submenu. Includes a left-pointing arrow before the word 'Back'.">
        <ph name="ARROW">←</ph> Back
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_BACK_BUTTON_ACCESSIBLE_NAME" desc="Accessible name for the back button in the Control Center 'More' submenu (no arrow, screen reader friendly).">
        Back
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_SHARE" desc="Label on the button in the Control Center 'More' submenu that opens the native share sheet for the current page.">
        Share
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_CLEAR_CACHE" desc="Label on the button in the Control Center 'More' submenu that clears the browser cache. Idle state.">
        Clear Cache
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_CLEAR_COOKIES" desc="Label on the button in the Control Center 'More' submenu that clears the browser cookies. Idle state.">
        Clear Cookies
      </message>
      <message name="IDS_DAO_CONTROL_CENTER_CLEARING" desc="Transient label shown on a Clear Cache or Clear Cookies button while the operation is in progress.">
        Clearing...
      </message>
      <message name="IDS_DAO_FORCE_DARK_MODE_LABEL" desc="Accessible label for a toggle button that remembers whether Dao should force websites into dark mode while the system appearance is dark.">
        Force dark mode
      </message>
      <message name="IDS_DAO_FORCE_DARK_MODE_SHORT_LABEL" desc="Short label shown under the Control Center utility button for the force dark mode toggle.">
        Dark
      </message>
      <message name="IDS_DAO_FORCE_DARK_MODE_TOOLTIP" desc="Tooltip for the Force dark mode toggle when it can be changed because the system appearance is dark.">
        Darken websites with Auto Dark Mode while the system is in dark mode.
      </message>
      <message name="IDS_DAO_FORCE_DARK_MODE_DISABLED_TOOLTIP" desc="Tooltip for the Force dark mode toggle when it is disabled because the system appearance is light.">
        Available when the system is in dark mode.
      </message>

      <!-- QR code dialog (after scanning a QR via right-click on an image) -->
      <message name="IDS_DAO_CONTEXT_MENU_DECODE_QR_CODE" desc="Image right-click context menu item that decodes any QR code embedded in the image and shows the result.">
        Decode QR Code
      </message>
      <message name="IDS_DAO_QR_NO_CODE_FOUND" desc="Toast shown when the user invoked Decode QR Code on an image but no QR code could be decoded.">
        No QR code found
      </message>
      <message name="IDS_DAO_QR_RESULT_DIALOG_TITLE" desc="Title of the dialog shown when a QR code in the page has been decoded.">
        QR Code Result
      </message>
      <message name="IDS_DAO_QR_RESULT_COPY" desc="Label on a button that copies the decoded QR text to the clipboard.">
        Copy
      </message>
      <message name="IDS_DAO_QR_RESULT_OPEN" desc="Label on a button that opens the decoded QR text as a URL in a new tab.">
        Open
      </message>

      <!-- Little Dao mini-browser window -->
      <message name="IDS_DAO_LITTLE_DAO_ADDRESS_ACCESSIBLE_NAME" desc="Accessible name for the URL display field in the Little Dao mini-browser window.">
        Address
      </message>
      <message name="IDS_DAO_LITTLE_DAO_OPEN_IN_DAO_ACCESSIBLE_NAME" desc="Accessible name for the button that promotes the current Little Dao mini-browser tab into a full Dao Browser tab.">
        Open in Dao
      </message>
      <message name="IDS_DAO_MINI_DAO_SITE_CENTER_ACCESSIBLE_NAME" desc="Accessible name for the site center button inside the Mini Dao URL pill.">
        Site center
      </message>
      <message name="IDS_DAO_MINI_DAO_SITE_CENTER_EXTENSIONS_LABEL" desc="Section heading for extension actions inside the Mini Dao site center.">
        Extensions on this site
      </message>
      <message name="IDS_DAO_MINI_DAO_SITE_CENTER_PAGE_INFO" desc="Button label for opening Page Info from the Mini Dao site center.">
        Site settings
      </message>
      <message name="IDS_DAO_MINI_DAO_SITE_CENTER_SHARE" desc="Button label for sharing the current page from the Mini Dao site center.">
        Share
      </message>
      <message name="IDS_DAO_MINI_DAO_SITE_CENTER_QR_CODE" desc="Button label for showing a QR code for the current page from the Mini Dao site center.">
        QR Code
      </message>
      <message name="IDS_DAO_MINI_DAO_SITE_CENTER_MORE" desc="Button label for additional current-site actions inside the Mini Dao site center.">
        More
      </message>
      <message name="IDS_DAO_MINI_DAO_SITE_CENTER_BACK_BUTTON_LABEL" desc="Label for returning from a Mini Dao site center sub-panel to the main site center panel. Includes a left-pointing arrow before the word Back.">
        <ph name="ARROW">←</ph> Back
      </message>
      <message name="IDS_DAO_MINI_DAO_SITE_CENTER_BACK_BUTTON_ACCESSIBLE_NAME" desc="Accessible name for returning from a Mini Dao site center sub-panel to the main site center panel.">
        Back
      </message>
      <message name="IDS_DAO_MINI_DAO_DOWNLOAD_CARD_CANCEL" desc="Accessible name and tooltip for the button that cancels one active download in the Mini Dao download progress card.">
        Cancel download
      </message>
      <message name="IDS_DAO_MINI_DAO_DOWNLOAD_CARD_OVERFLOW" desc="Summary line in the Mini Dao download progress card when more active downloads exist than can be shown. COUNT is the number of additional active downloads hidden behind the summary.">
        <ph name="COUNT">$1<ex>3</ex></ph> more
      </message>
      <!-- Install dialog notice -->
      <message name="IDS_DAO_INSTALL_PROMPT_LEGACY_MV2_NOTICE" desc="One-line notice shown above the permission list in the extension install dialog when the extension being installed is a legacy Manifest V2 extension. Tells the user that Dao still supports MV2 but most other browsers do not. Plain text, no link.">
        This is a legacy (Manifest V2) extension. Dao supports it; Chrome and most other browsers no longer do.
      </message>
    </messages>
  </release>
</grit>
