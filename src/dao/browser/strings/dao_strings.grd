    <output filename="dao_strings_sr-Latn.pak" type="data_package" lang="sr-Latn" />
    <output filename="dao_strings_sr.pak" type="data_package" lang="sr" />
    <output filename="dao_strings_sv.pak" type="data_package" lang="sv" />
    <output filename="dao_strings_sw.pak" type="data_package" lang="sw" />
    <output filename="dao_strings_ta.pak" type="data_package" lang="ta" />
    <output filename="dao_strings_te.pak" type="data_package" lang="te" />
    <output filename="dao_strings_th.pak" type="data_package" lang="th" />
    <output filename="dao_strings_tr.pak" type="data_package" lang="tr" />
    <output filename="dao_strings_uk.pak" type="data_package" lang="uk" />
    <output filename="dao_strings_ur.pak" type="data_package" lang="ur" />
    <output filename="dao_strings_uz.pak" type="data_package" lang="uz" />
    <output filename="dao_strings_vi.pak" type="data_package" lang="vi" />
    <output filename="dao_strings_zh-CN.pak" type="data_package" lang="zh-CN" />
    <output filename="dao_strings_zh-HK.pak" type="data_package" lang="zh-HK" />
    <output filename="dao_strings_zh-TW.pak" type="data_package" lang="zh-TW" />
    <output filename="dao_strings_zu.pak" type="data_package" lang="zu" />
    <!-- Pseudolocales -->
    <output filename="dao_strings_ar-XB.pak" type="data_package" lang="ar-XB" />
    <output filename="dao_strings_en-XA.pak" type="data_package" lang="en-XA" />
  </outputs>
  <translations>
    <file path="translations/dao_strings_af.xtb" lang="af" />
    <file path="translations/dao_strings_am.xtb" lang="am" />
    <file path="translations/dao_strings_ar.xtb" lang="ar" />
    <file path="translations/dao_strings_as.xtb" lang="as" />
    <file path="translations/dao_strings_az.xtb" lang="az" />
    <file path="translations/dao_strings_be.xtb" lang="be" />
    <file path="translations/dao_strings_bg.xtb" lang="bg" />
    <file path="translations/dao_strings_bn.xtb" lang="bn" />
    <file path="translations/dao_strings_bs.xtb" lang="bs" />
    <file path="translations/dao_strings_ca.xtb" lang="ca" />
    <file path="translations/dao_strings_cs.xtb" lang="cs" />
    <file path="translations/dao_strings_cy.xtb" lang="cy" />
    <file path="translations/dao_strings_da.xtb" lang="da" />
    <file path="translations/dao_strings_de.xtb" lang="de" />
    <file path="translations/dao_strings_el.xtb" lang="el" />
    <file path="translations/dao_strings_en-GB.xtb" lang="en-GB" />
    <file path="translations/dao_strings_es.xtb" lang="es" />
    <file path="translations/dao_strings_es-419.xtb" lang="es-419" />
    <file path="translations/dao_strings_et.xtb" lang="et" />
    <file path="translations/dao_strings_eu.xtb" lang="eu" />
