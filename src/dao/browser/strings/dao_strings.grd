    <file path="translations/dao_strings_hr.xtb" lang="hr" />
    <file path="translations/dao_strings_hu.xtb" lang="hu" />
    <file path="translations/dao_strings_hy.xtb" lang="hy" />
    <file path="translations/dao_strings_id.xtb" lang="id" />
    <file path="translations/dao_strings_is.xtb" lang="is" />
    <file path="translations/dao_strings_it.xtb" lang="it" />
    <!-- The translation console uses 'iw' for Hebrew, but we use 'he'. -->
    <file path="translations/dao_strings_iw.xtb" lang="he" />
