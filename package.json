{
  "name": "dao-browser",
  "version": "0.1.0",
  "description": "A Chromium-based browser with vertical tab sidebar",
  "type": "module",
  "scripts": {
    "dao": "tsx scripts/cli.ts",
    "download": "tsx scripts/cli.ts download",
    "import": "tsx scripts/cli.ts import",
    "export": "tsx scripts/cli.ts export",
    "build": "tsx scripts/cli.ts build",
    "build:debug": "tsx scripts/cli.ts build --debug",
    "start": "open 'engine/src/out/dao/Dao Browser.app' --args --use-mock-keychain",
    "start:debug": "'engine/src/out/dao-debug/Dao Browser.app/Contents/MacOS/Dao Browser' --use-mock-keychain --enable-logging=stderr --log-level=2",
    "start:debug:view": "'engine/src/out/dao-debug/Dao Browser.app/Contents/MacOS/Dao Browser' --use-mock-keychain --enable-ui-devtools=9223 --enable-logging=stderr --v=1",
    "start:little": "open -a \"$(pwd)/engine/src/out/dao/Dao Browser.app\" 'https://bing.com' --args --use-mock-keychain",
    "package": "tsx scripts/cli.ts package",
    "package:zip": "tsx scripts/cli.ts package --zip",
    "setup": "npm run download && npm run import",
    "rebuild": "npm run import && npm run build:debug",
    "test": "tsx scripts/cli.ts build --debug --target browser_tests && engine/src/out/dao-debug/browser_tests --gtest_filter=\"Dao*\"",
    "gen:readability": "tsx scripts/gen_readability_bundle.ts"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.1",
    "tsx": "^4.19.0"
  },
  "license": "MPL-2.0"
}
